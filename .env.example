# LAN Monitor Configuration
# Copy this file to .env and adjust values for your environment

# Database
DATABASE_URL=sqlite:////data/db/lan_monitor.db

# Network Scanning
SCAN_CIDR=192.168.1.0/24
SCAN_INTERVAL_MINUTES=30
NMAP_ARGS=-sV --open -T4

# Log Paths (inside container)
ZEEK_LOG_DIR=/data/logs/zeek
SURICATA_LOG_PATH=/data/logs/suricata/eve.json
ROUTER_SYSLOG_PATH=/data/logs/router/syslog

# Scoring Thresholds
OUTBOUND_FANOUT_THRESHOLD=50
SUSTAINED_UPLOAD_THRESHOLD_MB=500.0
LONG_LIVED_SESSION_THRESHOLD_SEC=3600
LONG_LIVED_SESSION_COUNT_THRESHOLD=3
DNS_CHURN_THRESHOLD=100
DOMAIN_DIVERSITY_NXDOMAIN_THRESHOLD=20
GEO_ASN_SPREAD_THRESHOLD=10
BEHAVIOR_DEVIATION_Z_THRESHOLD=2.5

# IoT weight multiplier
IOT_WEIGHT_MULTIPLIER=1.5

# Alert sensitivity
ALERT_SCORE_CHANGE_THRESHOLD=10.0

# GeoIP (optional)
USE_GEOIP=false
# GEOIP_DB_PATH=/data/GeoLite2-City.mmdb

# Baseline window
BASELINE_WINDOW_HOURS=168
BASELINE_COMPUTE_INTERVAL_HOURS=24

# LLM Analysis (optional)
# Set LLM_ENABLED=true and configure your provider
LLM_ENABLED=false
LLM_PROVIDER=ollama         # ollama | lmstudio
LLM_BASE_URL=http://localhost:11434   # Ollama default; LM Studio: http://localhost:1234
LLM_MODEL=llama3.2          # Any model you have pulled in Ollama / loaded in LM Studio
